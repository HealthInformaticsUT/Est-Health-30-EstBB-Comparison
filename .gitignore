# R session state — never commit
.Rhistory
.RData
.RDataTmp
.RDataTmp1
.RDataTmp2
.Rapp.history

# RStudio project state
.Rproj.user/
*.Rproj.bak

# macOS / Windows
.DS_Store
Thumbs.db

# Profiling artefacts (large HTMLs + supporting files)
profvis_runs/
profvis_result*.html

# Backups + old code
*.bak

# Internal screenshots (article submission artefacts, not runtime)
Screenshot*.png

# Internal development log (workfile, kept local)
PROJECT.md

# Data — both CSVs (canonical, for the paper supplement) and parquet
# (runtime acceleration cache) are committed. Provenance documented in
# scripts/regenerate_data.R.

# rsconnect deploy state may contain account-specific identifiers — keep local
rsconnect/

# Editor / OS scratch
*.swp
*~

# Heterogeneity sidecars — generated locally for completeness but NOT shipped
# to GitHub (no reviewer asked for them; the article supplementary doesn't
# document them). Decision recorded 2026-05-15.
# Patterns broadened 2026-05-15 (#2) to catch any current OR future demo-output
# subfolder name (e.g. `demo_comp_data/`, `KEEP_demo_comp_data/`, snapshot
# folders); the `**` glob matches any depth under `demo_comparison_script/`.
comp_data/*_heterogeneity.csv
demo_comparison_script/**/*_heterogeneity.csv
